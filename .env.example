# Flesh Pulse — Environment Configuration

# ── Database (required) ────────────────────────────────────────────────────────
# Local Docker:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flesh_pulse
# Supabase (swap in production):
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── AI curation (required) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── News sources ───────────────────────────────────────────────────────────────
# Optional — adds keyword search on top of RSS feeds
NEWSAPI_KEY=

# ── App settings ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
ADMIN_HOST=127.0.0.1
ADMIN_PASSWORD=
ADMIN_PORT=8001
DEBUG=false
LOG_LEVEL=INFO
COLLECTION_INTERVAL_MINUTES=60
MIN_RELEVANCE_SCORE=0.65
# Set to true/1 to skip NewsAPI during testing (RSS feeds still run)
DISABLE_NEWSAPI=false

# ── User authentication ────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production

# ── Email delivery (Resend) ────────────────────────────────────────────────────
RESEND_API_KEY=re_...
# Use onboarding@resend.dev for testing; swap to your verified domain when live
FROM_EMAIL=Flesh Pulse <onboarding@resend.dev>
CONTACT_EMAIL=contact@fleshpulse.com
APP_URL=http://localhost:8000

# ── Social sign-in (OAuth) ────────────────────────────────────────────────────
# Leave empty to disable a provider — buttons only appear for configured providers

# Google — console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn — linkedin.com/developers → My Apps
# Authorized redirect URI: http://localhost:8000/auth/linkedin/callback
# Products required: Sign In with LinkedIn using OpenID Connect
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Microsoft — portal.azure.com → App registrations
# Authorized redirect URI: http://localhost:8000/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Twitter / X posting — developer.twitter.com → Projects & Apps → Keys and tokens
TWITTER_HANDLE=fleshpulse
TWITTER_MAX_PER_RUN=1
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ── Stripe payments ────────────────────────────────────────────────────────────
# stripe.com → Developers → API keys (use sk_test_... for development)
STRIPE_SECRET_KEY=sk_test_...

# ── Testing ────────────────────────────────────────────────────────────────────
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flesh_pulse_test
